// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


//リレーションの方法　fieldsはこちら側が現在参照しようとしている外部キーの値で、referencesはその値がどこにあるかを示す外部の主キー
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// datasource db {
//   provider = "postgresql"
// }

model User {
  id    BigInt @id @default(autoincrement())
  name  String @unique
  password String
  deck Deck[]
  historyAsUser1 History[] @relation("User1")
  historyAsUser2 History[] @relation("User2")

  isadmin Boolean @default(false)

  joined_At DateTime @default(now())
  created_At DateTime @default(now())
  updated_At DateTime @updatedAt 
}

model Deck {
  id BigInt @id @default(autoincrement())
  name String
  description String?
  userId BigInt 
  user    User       @relation(fields: [userId], references: [id])
  cards   Deck_Card[]

  @@index([userId])
  @@index([userId, name])

}

enum Cardtype{
  Character
  Spell
  Trap
}

model Card {
  id        BigInt @id @default(autoincrement())
  name      String
  cardtype Cardtype //カードの種類（キャラクター・スペル・トラップ）
  race_id BigInt[] // 種族ID
  race Race @relation(fields: [race_id], references: [id])

  power BigInt?
  level Int?
  effect Json? 

  flavorText String?

  regulation Int @default(0) 
  pack_id BigInt
  pack Pack @relation(fields:[pack_id], references:[id])
  created_At DateTime @default(now())

  deck_Card Deck_Card[]

  @@index([name])
  @@index([cardtype])
}
// 種族テーブル
model Race {
  id   BigInt    @id @default(autoincrement())
  name String @unique

  cards Card[]
}
//パックの観念の追加
model Pack {
  id BigInt @id @default(autoincrement())
  name String @unique
  cards Card[]
  Closed Boolean @default(false)
}
//中間テーブル　Deck_Cardは、DeckとCardの多対多の関係を表しています。deck_Idとcard_Idの組み合わせが一意であることを保証するために、@@id([deck_Id, card_Id])が使用されています。また、onDelete: Cascadeオプションにより、親レコードが削除されたときに関連する子レコードも自動的に削除されるようになっています。
model Deck_Card {
  deck_Id BigInt
  card_Id BigInt
  count  Int @default(1)
  historyFlug Boolean @default(false)

  deck Deck @relation(fields: [deck_Id], references: [id], onDelete: Cascade)
  card Card @relation(fields: [card_Id], references: [id], onDelete: Cascade)
//onDelete:Cascadeとは、親レコードが削除されたときに子レコードも自動的に削除されることを意味します。これにより、データの整合性が保たれます。
  @@id([deck_Id, card_Id])//複合キー
}
//対戦履歴を保存するテーブル
model History {
  id BigInt @id @default(autoincrement())
  user_1_Id BigInt
  user_2_Id BigInt
  deck_1_ID BigInt @unique
  deck_2_ID BigInt @unique

  deck_1 HistoryDeck @relation("Deck1", fields: [deck_1_ID], references: [id])
  deck_2 HistoryDeck @relation("Deck2", fields: [deck_2_ID], references: [id])
  user_1 User @relation("User1", fields: [user_1_Id], references: [id])
  user_2 User @relation("User2", fields: [user_2_Id], references: [id])

  log Json
  created_At DateTime @default(now())
}

model HistoryDeck{
  id BigInt @id @default(autoincrement())
  history1 History? @relation("Deck1")
  history2 History? @relation("Deck2")
}
