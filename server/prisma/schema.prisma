// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


//リレーションの方法　fieldsはこちら側が現在参照しようとしている外部キーの値で、referencesはその値がどこにあるかを示す外部の主キー
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id    Int @id @default(autoincrement())
  name  String @unique
  password String
  deck Deck[]
  historyAsUser1 History[] @relation("User1")
  historyAsUser2 History[] @relation("User2")

  isadmin Boolean @default(false)

  joinedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

model Deck {
  id Int @id @default(autoincrement())
  name String
  description String?
  userId Int 
  user    User       @relation(fields: [userId], references: [id])
  cards   DeckCard[]

  @@index([userId])
  @@index([userId, name])

}

enum Cardtype{
  Character
  Spell
  Trap
}

model Card {
  id        Int @id @default(autoincrement())
  name      String
  cardtype Cardtype //カードの種類（キャラクター・スペル・トラップ）
  raceid Int // 種族ID
  race Race @relation(fields: [raceid], references: [id])

  Power Int?
  level Int?
  effect Json? 

  flavorText String?

  regulation Int @default(0) 
  pack String
  createdAt DateTime @default(now())

  deckCards DeckCard[]

  @@index([name])
  @@index([cardtype])
}
// 種族テーブル
model Race {
  id   Int    @id @default(autoincrement())
  name String @unique

  cards Card[]
}
//中間テーブル　DeckCardは、DeckとCardの多対多の関係を表しています。deckIdとcardIdの組み合わせが一意であることを保証するために、@@id([deckId, cardId])が使用されています。また、onDelete: Cascadeオプションにより、親レコードが削除されたときに関連する子レコードも自動的に削除されるようになっています。
model DeckCard {
  deckId Int
  cardId Int
  count  Int @default(1)
  historyFlug Boolean @default(false)

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
//onDelete:Cascadeとは、親レコードが削除されたときに子レコードも自動的に削除されることを意味します。これにより、データの整合性が保たれます。
  @@id([deckId, cardId])//複合キー
}
//対戦履歴を保存するテーブル
model History {
  id Int @id @default(autoincrement())
  user_1_Id Int
  user_2_Id Int
  Deck_1_ID Int @unique
  Deck_2_ID Int @unique

  Deck_1 HistoryDeck @relation("Deck1", fields: [Deck_1_ID], references: [id])
  Deck_2 HistoryDeck @relation("Deck2", fields: [Deck_2_ID], references: [id])
  User_1 User @relation("User1", fields: [user_1_Id], references: [id])
  User_2 User @relation("User2", fields: [user_2_Id], references: [id])

  log Json
  created_at DateTime @default(now())
}

model HistoryDeck{
  id Int @id @default(autoincrement())
  history1 History? @relation("Deck1")
  history2 History? @relation("Deck2")
}
