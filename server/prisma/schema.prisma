// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User {
  id    BigInt @id @default(autoincrement())
  name  String @unique
  password String
  deck Deck[]
  cards Card[]
  packs Pack[]
  historyAsUser1 History[] @relation("User1")
  historyAsUser2 History[] @relation("User2")

  isadmin Boolean @default(false)

  joined_At DateTime @default(now())
  created_At DateTime @default(now())
  updated_At DateTime @updatedAt
}

model Deck {
  id BigInt @id @default(autoincrement())
  name String
  description String?
  userId BigInt 
  user    User       @relation(fields: [userId], references: [id])
  cards   Deck_Card[]

  @@index([userId])
  @@unique([userId, name])
}

enum Cardtype{
  Character
  Spell
  Trap
}

model Card {
  id        BigInt @id @default(autoincrement())
  name      String @unique
  cardtype Cardtype //カードの種類（キャラクター・スペル・トラップ）
  // 種族・パックは中間テーブルで管理するため、ID配列は持たせません
  Race Card_Race[]
  power BigInt?
  level Int?
  effect Json? 

  flavorText String?

  regulation Int @default(0) 
  card_Pack Card_Pack[]
  created_At DateTime @default(now())
  made_by BigInt
  artist User @relation(fields: [made_by], references: [id])
  deck Deck_Card[]

  @@index([name])
  @@index([cardtype])
}
// 種族テーブル
model Race {
  id   BigInt    @id @default(autoincrement())
  name String @unique

  cards Card_Race[]
}
//パック
model Pack {
  id BigInt @id @default(autoincrement())
  name String @unique
  cards Card_Pack[]
  Closed Boolean @default(false)
  made_by BigInt //作成者ID
  artist User @relation(fields: [made_by], references: [id])
}
//中間テーブル　Deck_Cardは、DeckとCardの多対多の関係を表しています。deck_Idとcard_Idの組み合わせが一意であることを保証するために、@@id([deck_Id, card_Id])が使用されています。また、onDelete: Cascadeオプションにより、親レコードが削除されたときに関連する子レコードも自動的に削除されるようになっています。
model Deck_Card {
  deck_Id BigInt
  card_Id BigInt
  count  Int @default(1)
  historyFlug Boolean @default(false)

  deck Deck @relation(fields: [deck_Id], references: [id], onDelete: Cascade)
  card Card @relation(fields: [card_Id], references: [id], onDelete: Cascade)
//onDelete:Cascadeとは、親レコードが削除されたときに子レコードも自動的に削除されることを意味します。これにより、データの整合性が保たれます。
  @@id([deck_Id, card_Id])//複合キー
}
model Card_Pack {
  card_Id BigInt
  pack_Id BigInt

  card Card @relation(fields: [card_Id], references: [id], onDelete: Cascade)
  pack Pack @relation(fields: [pack_Id], references: [id], onDelete: Cascade)

  @@id([card_Id, pack_Id])
}
model Card_Race{
  card_Id BigInt
  race_Id BigInt

  card Card @relation(fields: [card_Id], references: [id], onDelete: Cascade)
  race Race @relation(fields: [race_Id], references: [id], onDelete: Cascade)

  @@id([card_Id, race_Id])
}
//対戦履歴を保存するテーブル
model History {
  id BigInt @id @default(autoincrement())
  user_1_Id BigInt
  user_2_Id BigInt
  deck_1_ID BigInt
  deck_2_ID BigInt

  deck_1 HistoryDeck @relation("Deck1", fields: [deck_1_ID], references: [id], onDelete: Cascade)
  deck_2 HistoryDeck @relation("Deck2", fields: [deck_2_ID], references: [id], onDelete: Cascade)
  user_1 User @relation("User1", fields: [user_1_Id], references: [id], onDelete: Cascade)
  user_2 User @relation("User2", fields: [user_2_Id], references: [id], onDelete: Cascade)

  log Json
  created_At DateTime @default(now())
}

model HistoryDeck{
  id BigInt @id @default(autoincrement())
  history1 History[] @relation("Deck1")
  history2 History[] @relation("Deck2")
}
